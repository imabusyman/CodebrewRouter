{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "LlmGateway": {
    "Providers": {
      "AzureFoundry": {
        "Model": "gpt-4o"
      },
      "FoundryLocal": {
        "Endpoint": "http://localhost:5273",
        "Model": "",
        "ApiKey": "notneeded"
      },
      "OllamaLocal": {
        "BaseUrl": "http://localhost:11434",
        "Model": "llama3.2"
      }
    },
    "Routing": {
      "RouterModel": "router",
      "FallbackDestination": "AzureFoundry",
      "FailoverChains": {
        "AzureFoundry": ["FoundryLocal"],
        "FoundryLocal": ["AzureFoundry"]
      }
    },
    "CodebrewRouter": {
      "Enabled": true,
      "ModelId": "codebrewRouter",
      "FallbackRules": {
        "Reasoning":             ["AzureFoundry", "FoundryLocal"],
        "Coding":                ["AzureFoundry", "FoundryLocal"],
        "Research":              ["AzureFoundry", "FoundryLocal"],
        "VisionObjectDetection": ["AzureFoundry", "FoundryLocal"],
        "Creative":              ["AzureFoundry", "FoundryLocal"],
        "DataAnalysis":          ["AzureFoundry", "FoundryLocal"],
        "General":               ["AzureFoundry", "FoundryLocal"]
      }
    }
  }
}
