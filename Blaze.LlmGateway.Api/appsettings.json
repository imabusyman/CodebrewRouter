{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.AspNetCore.Hosting": "Debug",
      "Microsoft.AspNetCore.Routing": "Debug",
      "System.Net.Http": "Debug",
      "Blaze.LlmGateway": "Debug",
      "Blaze.LlmGateway.Infrastructure": "Debug",
      "Microsoft.Extensions.AI": "Debug"
    }
  },
  "AllowedHosts": "*",
  "LlmGateway": {
    "Providers": {
      "OllamaRouter": {
        "PrimaryEndpoint": "http://192.168.16.12:11434",
        "FallbackEndpoint": "https://codellama.local.codebrewco.net",
        "Model": "gemma4:e4b",
        "MaxContextTokens": 32768,
        "ReservedOutputTokens": 2048
      },
      "LmStudio": {
        "Endpoint": "http://192.168.16.56:1234/v1",
        "Model": "codebrew_balanced",
        "MaxContextTokens": 32768,
        "ReservedOutputTokens": 2048,
        "ApiKey": ""
      }
    },
    "Routing": {
      "RouterModel": "router",
      "FallbackDestination": "OllamaRouter",
      "FailoverChains": {
        "OllamaRouter": [],
        "LmStudio": []
      }
    },
    "CodebrewRouter": {
      "Enabled": true,
      "ModelId": "codebrewRouter",
      "FallbackRules": {
        "Reasoning":             ["OllamaRouter", "LmStudio"],
        "Coding":                ["OllamaRouter", "LmStudio"],
        "Research":              ["OllamaRouter", "LmStudio"],
        "VisionObjectDetection": ["OllamaRouter", "LmStudio"],
        "Creative":              ["OllamaRouter", "LmStudio"],
        "DataAnalysis":          ["OllamaRouter", "LmStudio"],
        "General":               ["OllamaRouter", "LmStudio"]
      },
      "ContextCompaction": {
        "Enabled": true,
        "TargetBudgetRatio": 0.85,
        "MinMessagesToCompact": 6,
        "PreserveMostRecentMessages": 4,
        "SummaryMaxOutputTokens": 256,
        "SummaryTemperature": 0.0
      }
    },
    "Availability": {
      "Enabled": false
    },
    "PromptCleanup": {
      "Enabled": true,
      "MaxOutputTokens": 256,
      "Temperature": 0.0,
      "MinLengthChars": 80,
      "CooldownMinutes": 5
    },
    "TaskClassification": {
      "Enabled": true,
      "MaxOutputTokens": 50,
      "Temperature": 0.0,
      "CooldownMinutes": 5
    }
  }
}
