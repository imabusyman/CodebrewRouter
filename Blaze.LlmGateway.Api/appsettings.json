{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "LlmGateway": {
    "Providers": {
      "AzureFoundry": {
        "Model": "gpt-4o"
      },
      "GithubCopilot": {
        "Endpoint": "https://api.githubcopilot.com",
        "Model": "gpt-4o"
      },
      "Gemini": {
        "Model": "gemini-2.0-flash"
      },
      "OpenRouter": {
        "Endpoint": "https://openrouter.ai/api/v1",
        "Model": "qwen/qwen3-235b-a22b:free"
      },
      "FoundryLocal": {
        "Endpoint": "http://localhost:5273",
        "Model": "",
        "ApiKey": "notneeded"
      },
      "GithubModels": {
        "Endpoint": "https://models.inference.ai.azure.com",
        "Model": "gpt-4o-mini"
      },
      "OllamaLocal": {
        "BaseUrl": "http://localhost:11434",
        "Model": "llama3.2"
      }
    },
    "Routing": {
      "RouterModel": "router",
      "FallbackDestination": "AzureFoundry"
    },
    "CodebrewRouter": {
      "Enabled": true,
      "ModelId": "codebrewRouter",
      "FallbackRules": {
        "Reasoning":             ["AzureFoundry", "Gemini", "GithubCopilot", "GithubModels"],
        "Coding":                ["GithubCopilot", "AzureFoundry", "GithubModels", "OllamaLocal"],
        "Research":              ["AzureFoundry", "Gemini", "OpenRouter", "GithubModels"],
        "VisionObjectDetection": ["Gemini", "AzureFoundry", "GithubCopilot"],
        "Creative":              ["OpenRouter", "AzureFoundry", "GithubCopilot"],
        "DataAnalysis":          ["AzureFoundry", "Gemini", "OpenRouter"],
        "General":               ["AzureFoundry", "GithubModels", "OllamaLocal"]
      }
    }
  }
}
