{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.AspNetCore.Hosting": "Debug",
      "Microsoft.AspNetCore.Routing": "Debug",
      "System.Net.Http": "Debug",
      "Blaze.LlmGateway": "Debug",
      "Blaze.LlmGateway.Infrastructure": "Debug",
      "Microsoft.Extensions.AI": "Debug"
    }
  },
  "AllowedHosts": "*",
  "LlmGateway": {
    "OfflineOnly": true,
    "LocalInference": {
      "Enabled": true,
      "ModelPath": "",
      "CacheDirectory": ".llm-cache",
      "EnableChecksumValidation": false,
      "ThreadCount": 0,
      "MaxContextTokens": 4096,
      "Temperature": 0.7,
      "TopP": 0.9,
      "WarmupEnabled": true,
      "WarmupPrompt": "ready",
      "WarmupMaxOutputTokens": 1,
      "WarmupTimeoutSeconds": 120,
      "BlockStartupUntilWarm": true
    },
    "Providers": {
      "OllamaRouter": {
        "PrimaryEndpoint": "http://192.168.16.12:11434",
        "FallbackEndpoint": "https://codellama.local.codebrewco.net",
        "Model": "gemma4:e4b",
        "MaxContextTokens": 32768,
        "ReservedOutputTokens": 2048
      },
      "LmStudio": {
        "Endpoint": "http://192.168.16.56:1234/v1",
        "Model": "codebrew_balanced",
        "MaxContextTokens": 32768,
        "ReservedOutputTokens": 2048,
        "ApiKey": ""
      },
      "OpenCodeGo": {
        "BaseUrl": "https://opencode.ai/zen/go/v1",
        "ApiKey": "",
        "MaxContextTokens": 128000,
        "ReservedOutputTokens": 16384
      }
    },
    "Routing": {
      "RouterModel": "router",
      "FallbackDestination": "OllamaRouter",
      "FailoverChains": {
        "OllamaRouter": [],
        "LmStudio": []
      }
    },
    "CodebrewRouter": {
      "Enabled": true,
      "ModelId": "codebrewRouter",
      "FallbackRules": {
        "Reasoning":             ["LocalGemma"],
        "Coding":                ["LocalGemma"],
        "Research":              ["LocalGemma"],
        "VisionObjectDetection": ["LocalGemma"],
        "Creative":              ["LocalGemma"],
        "DataAnalysis":          ["LocalGemma"],
        "General":               ["LocalGemma"]
      },
      "ContextCompaction": {
        "Enabled": true,
        "TargetBudgetRatio": 0.85,
        "MinMessagesToCompact": 6,
        "PreserveMostRecentMessages": 4,
        "SummaryMaxOutputTokens": 256,
        "SummaryTemperature": 0.0
      }
    },
    "Availability": {
      "Enabled": false
    },
    "PromptCleanup": {
      "Enabled": false,
      "MaxOutputTokens": 256,
      "Temperature": 0.0,
      "MinLengthChars": 80,
      "CooldownMinutes": 5
    },
    "TaskClassification": {
      "Enabled": false,
      "MaxOutputTokens": 50,
      "Temperature": 0.0,
      "CooldownMinutes": 5
    }
  }
}
