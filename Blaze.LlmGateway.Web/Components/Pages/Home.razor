@page "/"
@using System.Net.Http.Json
@using Blaze.LlmGateway.Core.ModelCatalog
@using Syncfusion.Blazor.InteractiveChat
@using System.Text
@using System.Text.Json
@inject IHttpClientFactory HttpClientFactory
@rendermode InteractiveServer

<PageTitle>AI Chat - Blaze LLM Gateway</PageTitle>

<div class="chat-container">
    <div class="model-picker card mb-3">
        <div class="card-body">
            <label class="form-label" for="modelSelect"><strong>Model</strong></label>
            <select id="modelSelect" class="form-select" @bind="selectedModelId" disabled="@isLoadingModels">
                @foreach (var model in availableModels)
                {
                    <option value="@model.Id">@model.Id (@model.Provider / @model.Source)</option>
                }
            </select>
        </div>
    </div>

    <SfAIAssistView @ref="assistView" PromptRequested="OnPromptRequested">
        <AssistViews>
            <AssistView Header="Blaze LLM Gateway" IconCss="e-icons e-assistview-icon">
                <BannerTemplate>
                    <div class="banner-content">
                        <div class="e-icons e-assistview-icon"></div>
                        <h3>How can I help you today?</h3>
                        <p>I can route your requests to local Foundry, GitHub Models, Gemini, and more.</p>
                    </div>
                </BannerTemplate>
            </AssistView>
        </AssistViews>
    </SfAIAssistView>
</div>

@code {
    private SfAIAssistView? assistView;
    private readonly StringBuilder currentResponse = new();
    private List<ModelOption> availableModels = [new("gpt-4o", "AzureFoundry", "fallback")];
    private string selectedModelId = "gpt-4o";
    private bool isLoadingModels;

    protected override async Task OnInitializedAsync()
    {
        await LoadModelsAsync();
    }

    private async Task LoadModelsAsync()
    {
        isLoadingModels = true;

        try
        {
            var client = HttpClientFactory.CreateClient();
            client.BaseAddress = new Uri("http://api");

            var response = await client.GetFromJsonAsync<ModelsEnvelope>("/v1/models");
            var models = response?.Data?
                .Where(model => !string.IsNullOrWhiteSpace(model.Id))
                .Select(model => new ModelOption(model.Id, model.Provider ?? "Unknown", model.Source ?? "configured"))
                .DistinctBy(model => model.Id, StringComparer.OrdinalIgnoreCase)
                .OrderBy(model => model.Provider, StringComparer.OrdinalIgnoreCase)
                .ThenBy(model => model.Id, StringComparer.OrdinalIgnoreCase)
                .ToList();

            if (models is { Count: > 0 })
            {
                availableModels = models;
                selectedModelId = availableModels[0].Id;
            }
        }
        catch
        {
            availableModels = [new("gpt-4o", "AzureFoundry", "fallback")];
            selectedModelId = availableModels[0].Id;
        }
        finally
        {
            isLoadingModels = false;
        }
    }

    private async Task OnPromptRequested(AssistViewPromptRequestedEventArgs args)
    {
        var userPrompt = args.Prompt;
        currentResponse.Clear();

        var client = HttpClientFactory.CreateClient();
        client.BaseAddress = new Uri("http://api");

        var requestBody = new
        {
            model = selectedModelId,
            messages = new[]
            {
                new { role = "user", content = userPrompt }
            },
            stream = true  // Always stream for better UX
        };

        var content = new StringContent(JsonSerializer.Serialize(requestBody), Encoding.UTF8, "application/json");
        
        using var request = new HttpRequestMessage(HttpMethod.Post, "/v1/chat/completions")
        {
            Content = content
        };

        try
        {
            using var response = await client.SendAsync(request, HttpCompletionOption.ResponseHeadersRead);
            response.EnsureSuccessStatusCode();

            using var stream = await response.Content.ReadAsStreamAsync();
            using var reader = new StreamReader(stream);

            while (await reader.ReadLineAsync() is { } line)
            {
                if (string.IsNullOrWhiteSpace(line)) continue;

                if (line.StartsWith("data: "))
                {
                    var data = line.Substring(6).Trim();
                    if (data == "[DONE]")
                    {
                        break;
                    }

                    try
                    {
                        using var doc = JsonDocument.Parse(data);
                        var text = doc.RootElement
                            .GetProperty("choices")[0]
                            .GetProperty("delta")
                            .GetProperty("content")
                            .GetString();

                        if (!string.IsNullOrEmpty(text))
                        {
                            currentResponse.Append(text);
                            // Update the UI with the partial response
                            args.Response = currentResponse.ToString();
                            StateHasChanged();
                        }
                    }
                    catch (JsonException)
                    {
                        // Ignore malformed chunks
                    }
                }
            }
        }
        catch (Exception ex)
        {
            args.Response = $"Error: {ex.Message}";
        }
    }

    private sealed record ModelOption(string Id, string Provider, string Source);

    private sealed record ModelsEnvelope(List<ModelInfoDto> Data);

    private sealed record ModelInfoDto(string Id, string? Provider, string? Source);
}

<style>
    .chat-container {
        height: calc(100vh - 100px);
        width: 100%;
        margin: 0 auto;
        padding: 20px;
    }

    .banner-content {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 50px;
        height: 100%;
    }

    .model-picker {
        max-width: 720px;
        margin: 0 auto 1rem auto;
    }

    .banner-content h3 {
        margin-top: 20px;
    }

    .e-assistview-icon::before {
        content: '\e70a';
        font-family: 'e-icons';
        font-size: 32px;
    }
</style>
